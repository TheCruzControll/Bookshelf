{
  "name": "bookshelf",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "test": "turbo test",
    "db:generate": "pnpm --filter @bookshelf/db db:generate",
    "db:migrate": "pnpm --filter @bookshelf/db db:migrate"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "prettier": "^3.5.0",
    "turbo": "^2.5.0",
    "typescript": "^5.9.0"
  }
}

