# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────
# Primary Postgres connection (local: docker-compose, prod: Supabase pooler)
DATABASE_URL="postgresql://hone:hone@localhost:5432/hone"

# ─────────────────────────────────────────────
# Supabase (hosted Postgres / Auth / Storage)
# ─────────────────────────────────────────────
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# ─────────────────────────────────────────────
# Auth — Apple Sign-In
# ─────────────────────────────────────────────
# Apple OAuth / Sign-in with Apple credentials
APPLE_CLIENT_ID=""
APPLE_TEAM_ID=""
APPLE_KEY_ID=""
# PEM-encoded private key from Apple Developer portal (p8 file contents)
APPLE_PRIVATE_KEY=""

# ─────────────────────────────────────────────
# Auth — Google Sign-In
# ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─────────────────────────────────────────────
# Auth — Phone Verification (Twilio Verify)
# ─────────────────────────────────────────────
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
# Twilio Verify Service SID (starts with VA...)
TWILIO_VERIFY_SERVICE_SID=""

# ─────────────────────────────────────────────
# Contacts Matching — KMS / HMAC
# ─────────────────────────────────────────────
# AWS KMS key ARN used to generate the monthly-rotating HMAC-SHA-256 salt
KMS_KEY_ARN=""
# AWS region where the KMS key lives
KMS_REGION=""
# AWS credentials for KMS access (use IAM role in production)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# ─────────────────────────────────────────────
# Catalog — Open Library
# ─────────────────────────────────────────────
# User-Agent sent with every Open Library API request
# Format: "AppName/version (contact@example.com)"
OPEN_LIBRARY_USER_AGENT="Hone/1.0 (dev@example.com)"

# ─────────────────────────────────────────────
# Catalog — Google Books (fallback)
# ─────────────────────────────────────────────
GOOGLE_BOOKS_API_KEY=""

# ─────────────────────────────────────────────
# Affiliate — Bookshop.org
# ─────────────────────────────────────────────
# US affiliate tag for Bookshop.org buy links
BOOKSHOP_AFFILIATE_ID_US=""
# UK affiliate tag for Bookshop.org buy links
BOOKSHOP_AFFILIATE_ID_UK=""

# ─────────────────────────────────────────────
# Observability — Sentry
# ─────────────────────────────────────────────
SENTRY_DSN=""
# Environment tag sent to Sentry (development | staging | production)
SENTRY_ENVIRONMENT="development"

# ─────────────────────────────────────────────
# API server
# ─────────────────────────────────────────────
# Port the Hono API listens on locally
PORT="8787"
# Public URL clients use to reach the API
NEXT_PUBLIC_API_URL="http://localhost:8787"
EXPO_PUBLIC_API_URL="http://localhost:8787"
